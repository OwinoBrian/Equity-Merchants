# Adjust this to the local static server you use for the frontend.
ALLOWED_ORIGIN=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:5500,http://localhost:5500
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX
AIRTABLE_TABLE_NAME=Listings
R2_PUBLIC_URL=https://pub-xxxx.r2.dev
AIRTABLE_API_KEY=replace-with-your-airtable-pat

# The R2 bucket binding itself lives in wrangler.toml:
# [[r2_buckets]]
# binding = "LISTINGS_IMAGES"
# bucket_name = "equity-merchants-images"
